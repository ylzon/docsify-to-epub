{
  "name": "docsify-to-epub",
  "version": "1.0.2",
  "description": "将 Docsify 文档站点转换为 EPUB 电子书",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/ylzon/docsify-to-epub",
  "author": "allenyan",
  "bin": {
    "dtoe": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm run release:npm && npm run release:gh",
    "release:npm": "npm publish",
    "release:gh": "npm pkg set name=@ylzon/docsify-to-epub && npm publish --registry=https://npm.pkg.github.com && git checkout package.json"
  },
  "keywords": [
    "docsify",
    "epub",
    "converter",
    "ebook",
    "documentation",
    "cli"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.0.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT"
}
